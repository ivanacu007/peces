<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');

    :root {
      --ocean: #003366;
      --ocean-mid: #005b8e;
      --cyan: #0097b2;
      --light-cyan: #e0f7ff;
      --text: #1a2a3a;
      --muted: #4a6070;
      --border: #b0d4e8;
      --accent: #00b4d8;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Raleway', sans-serif;
      color: var(--text);
      background: #fff;
      font-size: 11pt;
      line-height: 1.7;
    }

    /* ============================
       COVER PAGE
       ============================ */
    .cover {
      page-break-after: always;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      background: linear-gradient(160deg, #001529 0%, #003366 50%, #005b8e 100%);
      color: #fff;
    }

    .cover-top-bar {
      height: 6px;
      background: linear-gradient(90deg, #00f5d4, #00b4d8, #0068a0);
    }

    .cover-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 80px;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .cover-deco {
      font-size: 90px;
      margin-bottom: 30px;
      display: block;
      opacity: 0.9;
    }

    .cover-tag {
      display: inline-block;
      border: 1.5px solid rgba(0, 245, 212, 0.5);
      color: #00f5d4;
      font-size: 8pt;
      font-weight: 700;
      letter-spacing: 5px;
      text-transform: uppercase;
      padding: 6px 20px;
      border-radius: 50px;
      margin-bottom: 28px;
    }

    .cover-title {
      font-family: 'Playfair Display', serif;
      font-size: 52pt;
      font-weight: 700;
      line-height: 1.1;
      color: #fff;
      margin-bottom: 20px;
    }

    .cover-title em {
      font-style: italic;
      color: #00f5d4;
    }

    .cover-subtitle {
      font-size: 12pt;
      color: rgba(224, 247, 255, 0.75);
      max-width: 480px;
      margin: 0 auto 50px;
      font-weight: 300;
      line-height: 1.8;
    }

    .cover-divider {
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, transparent, #00b4d8, transparent);
      margin: 0 auto 50px;
    }

    .cover-meta {
      display: flex;
      gap: 50px;
      justify-content: center;
      font-size: 9pt;
      color: rgba(224, 247, 255, 0.6);
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .cover-meta strong {
      display: block;
      color: rgba(224, 247, 255, 0.9);
      font-size: 10pt;
      font-weight: 600;
      margin-bottom: 3px;
      letter-spacing: 1px;
    }

    .cover-footer {
      padding: 24px 80px;
      border-top: 1px solid rgba(255,255,255,0.1);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 8pt;
      color: rgba(224, 247, 255, 0.4);
    }

    .cover-brand {
      font-family: 'Playfair Display', serif;
      font-size: 11pt;
      color: #00b4d8;
      letter-spacing: 2px;
    }

    /* ============================
       TOC PAGE
       ============================ */
    .toc-page {
      page-break-after: always;
      padding: 70px 80px;
    }

    .toc-header {
      margin-bottom: 40px;
      padding-bottom: 16px;
      border-bottom: 2px solid var(--border);
    }

    .toc-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 22pt;
      color: var(--ocean);
    }

    .toc-item {
      display: flex;
      align-items: baseline;
      gap: 0;
      padding: 10px 0;
      border-bottom: 1px solid #f0f4f8;
    }

    .toc-num {
      font-size: 9pt;
      font-weight: 700;
      color: var(--cyan);
      letter-spacing: 2px;
      text-transform: uppercase;
      min-width: 40px;
    }

    .toc-title {
      font-size: 12pt;
      font-weight: 600;
      color: var(--text);
      flex: 1;
    }

    .toc-dots {
      flex: 1;
      border-bottom: 1px dotted var(--border);
      margin: 0 10px;
      min-width: 30px;
    }

    .toc-page-num {
      font-size: 10pt;
      color: var(--muted);
      font-weight: 600;
    }

    /* ============================
       CONTENT PAGES
       ============================ */
    .content-page {
      page-break-after: always;
      padding: 60px 80px;
    }

    .content-page:last-of-type {
      page-break-after: auto;
    }

    .page-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 36px;
      padding-bottom: 16px;
      border-bottom: 2px solid var(--border);
    }

    .page-num-badge {
      background: linear-gradient(135deg, var(--ocean), var(--cyan));
      color: #fff;
      font-size: 9pt;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 4px;
      flex-shrink: 0;
    }

    .page-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 22pt;
      color: var(--ocean);
      line-height: 1.2;
    }

    .section-intro {
      background: var(--light-cyan);
      border-left: 4px solid var(--accent);
      padding: 16px 20px;
      border-radius: 0 8px 8px 0;
      margin-bottom: 28px;
      font-size: 11pt;
      color: var(--muted);
      font-style: italic;
    }

    .subsection {
      margin-bottom: 26px;
    }

    .subsection h3 {
      font-family: 'Playfair Display', serif;
      font-size: 14pt;
      color: var(--ocean-mid);
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .subsection h3 .icon {
      font-size: 16pt;
    }

    .subsection p {
      font-size: 11pt;
      color: var(--text);
      line-height: 1.75;
    }

    .subsection strong { color: var(--ocean); }
    .subsection em { color: var(--cyan); font-style: italic; }

    /* Highlight box */
    .highlight {
      background: linear-gradient(135deg, rgba(0, 91, 142, 0.06), rgba(0, 180, 216, 0.06));
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 18px 22px;
      margin: 18px 0;
    }

    .highlight p {
      font-size: 10.5pt;
      color: var(--muted);
    }

    .highlight strong { color: var(--ocean); }

    /* Two columns */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 18px 0;
    }

    .col-box {
      background: #f7fbff;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
    }

    .col-box h4 {
      font-size: 10pt;
      font-weight: 700;
      color: var(--ocean-mid);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .col-box p {
      font-size: 9.5pt;
      color: var(--muted);
      line-height: 1.6;
    }

    /* Quote */
    .quote {
      margin: 22px 0;
      padding: 20px 28px;
      background: linear-gradient(135deg, #001529, #003366);
      border-radius: 10px;
      position: relative;
    }

    .quote blockquote {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 12pt;
      color: #e0f7ff;
      line-height: 1.7;
      margin-bottom: 8px;
    }

    .quote cite {
      font-size: 9pt;
      color: #00b4d8;
      font-style: normal;
      font-weight: 600;
    }

    /* ============================
       LIST STYLES
       ============================ */
    ul.styled {
      list-style: none;
      padding: 0;
      margin: 12px 0;
    }

    ul.styled li {
      padding: 6px 0 6px 22px;
      position: relative;
      font-size: 10.5pt;
      color: var(--text);
      border-bottom: 1px solid #f0f4f8;
    }

    ul.styled li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: var(--cyan);
      font-size: 9pt;
    }

    /* ============================
       REFERENCES PAGE
       ============================ */
    .ref-page {
      padding: 60px 80px;
    }

    .ref-page .page-header {
      margin-bottom: 30px;
    }

    .ref-item {
      display: flex;
      gap: 16px;
      padding: 16px 0;
      border-bottom: 1px solid #f0f4f8;
    }

    .ref-num {
      background: linear-gradient(135deg, var(--ocean), var(--cyan));
      color: #fff;
      font-size: 9pt;
      font-weight: 700;
      min-width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .ref-content { flex: 1; }

    .ref-year {
      display: inline-block;
      background: var(--light-cyan);
      color: var(--ocean-mid);
      font-size: 8pt;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      margin-bottom: 4px;
    }

    .ref-journal {
      font-size: 8.5pt;
      color: var(--cyan);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 3px;
    }

    .ref-title {
      font-family: 'Playfair Display', serif;
      font-size: 11pt;
      color: var(--text);
      font-weight: 700;
      margin-bottom: 3px;
    }

    .ref-authors {
      font-size: 9.5pt;
      color: var(--muted);
      font-style: italic;
      margin-bottom: 4px;
    }

    .ref-desc {
      font-size: 9.5pt;
      color: var(--muted);
      line-height: 1.5;
      margin-bottom: 5px;
    }

    .ref-url {
      font-size: 8.5pt;
      color: var(--cyan);
      word-break: break-all;
    }

    /* ============================
       PAGE FOOTER (all pages)
       ============================ */
    .page-foot {
      position: fixed;
      bottom: 20px;
      left: 80px;
      right: 80px;
      display: flex;
      justify-content: space-between;
      font-size: 7.5pt;
      color: #b0c4d8;
      border-top: 1px solid #e8f0f7;
      padding-top: 8px;
    }
  </style>
</head>
